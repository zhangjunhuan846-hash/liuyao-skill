{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "liuyao_feedback_schema_v2.json",
  "title": "Liuyao Feedback Schema v2",
  "description": "用于记录六爻案例反馈。重点不是只记准/不准，而是记录哪条判断、哪条规则、哪个时间窗被验证或被反驳。",
  "type": "object",
  "required": [
    "case_id",
    "feedback_id",
    "feedback_date",
    "mode_used",
    "overall_outcome",
    "verified_items",
    "learning_action"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "description": "对应 casebook 中的 case_id。"
    },
    "feedback_id": {
      "type": "string",
      "description": "反馈记录唯一 ID。建议格式：fb_YYYYMMDD_001。"
    },
    "feedback_date": {
      "type": "string",
      "format": "date"
    },
    "mode_used": {
      "type": "string",
      "enum": ["fresh", "literature_only", "school_comparison", "analogical_case", "posthoc_learning"]
    },
    "overall_outcome": {
      "type": "string",
      "enum": ["support", "partial", "reverse", "unverified", "abnormal"]
    },
    "case_summary": {
      "type": "string",
      "description": "简述原占事和最终现实结果。"
    },
    "verified_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prediction_item", "actual_result", "status", "rule_tags", "confidence_before"],
        "properties": {
          "prediction_item": {
            "type": "string",
            "description": "原判断中的具体条目，必须可验证，不要写泛泛判断。"
          },
          "actual_result": {
            "type": "string",
            "description": "现实发生的结果。"
          },
          "status": {
            "type": "string",
            "enum": ["support", "partial", "reverse", "unverified", "abnormal"]
          },
          "time_window": {
            "type": "string",
            "description": "原判断限定的时间窗，例如 7 days、申日、一个月内。"
          },
          "rule_tags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "yongshen",
                "shi_ying",
                "month_day_strength",
                "moving_lines",
                "changing_lines",
                "source_spirit",
                "avoid_spirit",
                "enemy_spirit",
                "six_relatives",
                "six_spirits",
                "line_position",
                "trigram_symbol",
                "branch_symbol",
                "feifushen",
                "emptiness",
                "tomb",
                "clash",
                "combine",
                "punishment_harm",
                "timing",
                "modern_case",
                "topic_rule",
                "other"
              ]
            }
          },
          "evidence_strength_before": {
            "type": "string",
            "enum": ["core_strong", "core_medium", "auxiliary", "symbolic_only", "unclear"]
          },
          "confidence_before": {
            "type": "string",
            "enum": ["high", "medium", "low", "insufficient"]
          },
          "confidence_after": {
            "type": "string",
            "enum": ["increase", "same", "decrease", "not_applicable"]
          },
          "failure_reason_hypothesis": {
            "type": "string",
            "description": "若判断失败，记录可能原因：用神取错、应期取窄、象意过度、信息缺失等。"
          }
        }
      }
    },
    "failed_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prediction_item", "actual_result", "suspected_reason"],
        "properties": {
          "prediction_item": {"type": "string"},
          "actual_result": {"type": "string"},
          "suspected_reason": {
            "type": "string",
            "enum": [
              "wrong_yongshen",
              "overweighted_six_spirits",
              "overweighted_modern_case",
              "ignored_month_day",
              "ignored_moving_line",
              "timing_too_narrow",
              "incomplete_chart",
              "question_boundary_unclear",
              "real_world_condition_changed",
              "unknown"
            ]
          },
          "notes": {"type": "string"}
        }
      }
    },
    "school_comparison_feedback": {
      "type": "array",
      "description": "若当时列出了多个流派，记录哪一路径更接近现实。",
      "items": {
        "type": "object",
        "properties": {
          "school_or_path": {"type": "string"},
          "prediction": {"type": "string"},
          "fit_to_actual": {
            "type": "string",
            "enum": ["best_fit", "partial_fit", "poor_fit", "not_verifiable"]
          },
          "notes": {"type": "string"}
        }
      }
    },
    "learning_action": {
      "type": "string",
      "enum": [
        "record_only",
        "add_to_unresolved_questions",
        "add_as_low_confidence_hypothesis",
        "mark_rule_for_review",
        "do_not_learn_from_abnormal_case"
      ]
    },
    "proposed_rule_update": {
      "type": "object",
      "description": "只有多案例重复支持时才允许升级为规则。单案例不得直接写成硬规则。",
      "properties": {
        "rule_text": {"type": "string"},
        "supporting_case_count": {"type": "integer", "minimum": 0},
        "opposing_case_count": {"type": "integer", "minimum": 0},
        "status": {
          "type": "string",
          "enum": ["hypothesis", "under_review", "accepted", "rejected"]
        }
      }
    }
  }
}
