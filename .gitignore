# Runtime private memory - do not publish
memory/casebook.jsonl
memory/feedback_log.jsonl
memory/*.jsonl
memory/*.yaml
memory/unresolved_questions.md
memory/version_log.md
memory/incoming_cases/*
!memory/README.md
!memory/.gitkeep
!memory/incoming_cases/.gitkeep
memory_backups/

# Generated indexes / reports
resources/index/*.jsonl
resources/index/*.json
resources/reports/*.csv
resources/reports/*.json
!resources/index/README.md
!resources/index/.gitkeep

# Raw OCR and local corpora may contain copyrighted/private text
resources/books_raw/*
resources/books_raw_md/*.md
resources/books_raw_md/*.txt
resources/books_corrected/*.md
resources/books_corrected/*.txt
resources/books_processed/*.jsonl
resources/books_processed/*.json
!resources/books_raw_md/README.md
!resources/books_raw_md/.gitkeep
!resources/books_corrected/README.md
!resources/books_corrected/.gitkeep
!resources/books_processed/README.md
!resources/books_processed/.gitkeep

# Raw PDFs and personal notes
raw_pdfs/*
notes/*
!raw_pdfs/README.md
!raw_pdfs/.gitkeep
!notes/README.md
!notes/.gitkeep

# Python / OS
__pycache__/
*.pyc
.DS_Store
Thumbs.db
.env
.venv/
venv/
